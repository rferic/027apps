{
  "openapi": "3.0.2",
  "paths": {
    "/api/v1": {
      "get": {
        "description": "Returns the API version and status. No authentication required.",
        "summary": "Health check",
        "tags": [
          "health"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "200",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "version": {
                      "type": "string",
                      "enum": [
                        "v1"
                      ]
                    },
                    "status": {
                      "type": "string",
                      "enum": [
                        "ok"
                      ]
                    }
                  },
                  "required": [
                    "version",
                    "status"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/apps": {
      "get": {
        "description": "Returns all active installed apps for the authenticated group. Authenticate with JWT or API key.",
        "summary": "List installed apps",
        "tags": [
          "apps"
        ],
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "200",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "slug": {
                        "type": "string"
                      },
                      "name": {
                        "type": "string"
                      },
                      "description": {
                        "type": "string",
                        "nullable": true
                      },
                      "icon_url": {
                        "type": "string",
                        "nullable": true
                      },
                      "status": {
                        "type": "string"
                      },
                      "visibility": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "slug",
                      "name",
                      "description",
                      "icon_url",
                      "status",
                      "visibility"
                    ]
                  }
                }
              }
            }
          },
          "401": {
            "description": "401",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/me": {
      "get": {
        "description": "Returns the authenticated user's profile information including display name, avatar, locale, role, and group membership.",
        "summary": "Get current user profile",
        "tags": [
          "me"
        ],
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "200",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "User UUID"
                    },
                    "email": {
                      "type": "string",
                      "description": "User email address"
                    },
                    "display_name": {
                      "type": "string",
                      "description": "Display name",
                      "nullable": true
                    },
                    "avatar_url": {
                      "type": "string",
                      "description": "Avatar URL",
                      "nullable": true
                    },
                    "locale": {
                      "type": "string",
                      "description": "Preferred locale code",
                      "nullable": true
                    },
                    "role": {
                      "type": "string",
                      "description": "User role: admin or member"
                    },
                    "group_id": {
                      "type": "string",
                      "description": "Primary group UUID"
                    }
                  },
                  "required": [
                    "id",
                    "email",
                    "display_name",
                    "avatar_url",
                    "locale",
                    "role",
                    "group_id"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "401",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          },
          "403": {
            "description": "403",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/locales": {
      "get": {
        "description": "Returns the active locales configured for the group, with their display names and default flag.",
        "summary": "List active locales",
        "tags": [
          "locales"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "200",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "code": {
                        "type": "string"
                      },
                      "name": {
                        "type": "string"
                      },
                      "is_default": {
                        "type": "boolean"
                      }
                    },
                    "required": [
                      "code",
                      "name",
                      "is_default"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/admin/apps/todo": {
      "get": {
        "description": "Returns all todo items across all groups. Requires admin role.",
        "summary": "List all todo items (admin)",
        "tags": [
          "admin",
          "apps",
          "todo"
        ],
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "200",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "number"
                      },
                      "title": {
                        "type": "string"
                      },
                      "completed": {
                        "type": "boolean"
                      },
                      "created_at": {
                        "type": "string"
                      },
                      "user_id": {
                        "type": "string"
                      },
                      "group_id": {
                        "type": "string"
                      },
                      "visibility": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "id",
                      "title",
                      "completed",
                      "created_at",
                      "user_id",
                      "group_id",
                      "visibility"
                    ]
                  }
                }
              }
            }
          },
          "401": {
            "description": "401",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          },
          "403": {
            "description": "403",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          },
          "500": {
            "description": "500",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "info": {
    "title": "027apps API",
    "version": "1.0.0",
    "description": "API pública de 027apps"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development"
    },
    {
      "url": "https://027app-eric-rf.vercel.app",
      "description": "Production"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}