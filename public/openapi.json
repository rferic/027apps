    "/api/v1": {
      "get": {
        "description": "Returns the API version and status. No authentication required.",
        "summary": "Health check",
        "tags": [
          "health"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "200",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "version": {
                      "type": "string",
                      "enum": [
                        "v1"
                      ],
                      "description": "API version"
                    },
                    "status": {
                      "type": "string",
                      "enum": [
                        "ok"
                      ],
                      "description": "Service status"
                    }
                  },
                  "required": [
                    "version",
                    "status"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/apps": {
      "get": {
        "description": "Returns all active installed apps for the authenticated group. Authenticate with JWT or API key.",
        "summary": "List installed apps",
        "tags": [
          "apps"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "200",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "slug": {
                        "type": "string",
                        "description": "Unique app identifier"
                      },
                      "name": {
                        "type": "string",
                        "description": "App display name"
                      },
                      "description": {
                        "type": "string",
                        "description": "App description",
                        "nullable": true
                      },
                      "icon_url": {
                        "type": "string",
                        "description": "App icon URL",
                        "nullable": true
                      },
                      "status": {
                        "type": "string",
                        "description": "App status: active, inactive"
                      },
                      "visibility": {
                        "type": "string",
                        "description": "App visibility: public, private"
                      }
                    },
                    "required": [
                      "slug",
                      "name",
                      "description",
                      "icon_url",
                      "status",
                      "visibility"
                    ]
                  }
                }
              }
            }
          },
          "401": {
            "description": "401",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code identifier"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error description"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKey": []
          }
        ]
      }
    },
    "/api/v1/me": {
      "get": {
        "description": "Returns the authenticated user's profile information including display name, avatar, locale, role, and group membership.",
        "summary": "Get current user profile",
        "tags": [
          "me"
        ],
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "200",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "User UUID"
                    },
                    "email": {
                      "type": "string",
                      "description": "User email address"
                    },
                    "display_name": {
                      "type": "string",
                      "description": "Display name",
                      "nullable": true
                    },
                    "avatar_url": {
                      "type": "string",
                      "description": "Avatar URL",
                      "nullable": true
                    },
                    "locale": {
                      "type": "string",
                      "description": "Preferred locale code",
                      "nullable": true
                    },
                    "role": {
                      "type": "string",
                      "description": "User role: admin or member"
                    },
                    "group_id": {
                      "type": "string",
                      "description": "Primary group UUID"
                    }
                  },
                  "required": [
                    "id",
                    "email",
                    "display_name",
                    "avatar_url",
                    "locale",
                    "role",
                    "group_id"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "401",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code, e.g. unauthorized"
                    },
                    "message": {
                      "type": "string",
                      "description": "Details about the authentication failure"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          },
          "403": {
            "description": "403",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code, e.g. forbidden"
                    },
                    "message": {
                      "type": "string",
                      "description": "Details about why access was denied"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
